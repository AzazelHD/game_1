{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Game Build (Debug)",
      "type": "shell",
      "command": "${workspaceFolder}/tools/build_debug.bat",
      "group": "build",
      "problemMatcher": ["$msCompile"]
    },
    {
      "label": "Game Build (Release)",
      "type": "shell",
      "command": "${workspaceFolder}/tools/build_release.bat",
      "group": "build",
      "problemMatcher": ["$msCompile"]
    },
    {
      "label": "Game DEV",
      "dependsOrder": "sequence",
      "dependsOn": ["Game Build (Debug)"],
      "problemMatcher": []
    },
    {
      "label": "Game FINAL",
      "dependsOrder": "sequence",
      "dependsOn": ["Game Build (Release)"],
      "problemMatcher": []
    },
    {
      "label": "Run Game",
      "type": "shell",
      "command": "game.exe",
      "options": {
        "cwd": "${workspaceFolder}/build/debug/game/Debug"
      },
      "problemMatcher": []
    },
    {
      "label": "Native Tools (x64)",
      "type": "shell",
      "command": "cmd.exe",
      "args": [
        "/k",
        "\"C:\\Program Files (x86)\\Microsoft Visual Studio\\18\\BuildTools\\Common7\\Tools\\VsDevCmd.bat\" -arch=x64"
      ],
      "problemMatcher": []
    }
  ]
}
